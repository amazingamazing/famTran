PORT=8787
HOST=0.0.0.0
DATABASE_PATH=./data/family-translation.sqlite
STT_PROVIDER=deepgram
TRANSLATION_PROVIDER=gemini
TTS_PROVIDER=cartesia
DEEPGRAM_API_KEY=
GEMINI_API_KEY=
CARTESIA_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CARTESIA_MODEL_ID=sonic-2
# Set to 1 to run parallel STT (Deepgram nova-2 + nova-3 + OpenAI whisper) per speech turn; costs extra. Timings in debug.turn + client debug log as stt.bench
# STT_BENCHMARK=1
# Set to 1 to stream 16kHz linear16 PCM to Deepgram over WebSocket (stt.deepgram_stream). Incompatible with STT_BENCHMARK (benchmark forces batch).
# STT_STREAM=1
# With STT_STREAM=1, debounced interim STT to the **speaker only** as transcript.live (no partial translations to listeners).
# LIVE_CAPTIONS=1
# After turn.stop, wait this many ms before STT → translate → TTS (0 = default; try 1000–1500 for trailing STT stability on JA).
# UTTERANCE_COMMIT_DELAY_MS=0
# Optional ms to wait after phrase pipelines drain and before closing Deepgram (helps trailing is_final). Default 250.
# STREAM_SEGMENT_SETTLE_MS=250
