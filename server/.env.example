PORT=8787
HOST=0.0.0.0
DATABASE_PATH=./data/family-translation.sqlite
STT_PROVIDER=deepgram
TRANSLATION_PROVIDER=gemini
TTS_PROVIDER=cartesia
DEEPGRAM_API_KEY=
GEMINI_API_KEY=
CARTESIA_API_KEY=
OPENAI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CARTESIA_MODEL_ID=sonic-2
# Set to 1 to run parallel STT (Deepgram nova-2 + nova-3 + OpenAI whisper) per speech turn; costs extra. Timings in debug.turn + client debug log as stt.bench
# STT_BENCHMARK=1
# Set to 1 to stream 16kHz linear16 PCM to Deepgram over WebSocket (stt.deepgram_stream). Incompatible with STT_BENCHMARK (benchmark forces batch).
# STT_STREAM=1
# With STT_STREAM=1, debounced interim STT to the **speaker only** as transcript.live (no partial translations to listeners).
# LIVE_CAPTIONS=1
# After turn.stop, wait this many ms before STT → translate → TTS (0 = default; try 1000–1500 for trailing STT stability on JA).
# UTTERANCE_COMMIT_DELAY_MS=0
# Optional ms after phrase pipelines drain before closing Deepgram (default 250).
# STREAM_SEGMENT_SETTLE_MS=250
# Live STT: optional silence (ms) before Deepgram ends a phrase (`is_final`). Higher = fewer splits, slightly later phrases. 0 = default.
# DEEPGRAM_LIVE_ENDPOINTING_MS=0
# Force a stream commit every N ms to prevent long-monologue latency drift (default 7000).
# FORCED_STREAM_COMMIT_MS=7000
# Minimum chars needed before forced stream commit can fire (default 24).
# FORCED_STREAM_COMMIT_MIN_CHARS=24
# While merged live transcript has no . ? ! or 。 yet AND length is at most this, each phrase final is translated immediately; after any sentence break in the merge, wait for full sentences even below this length (default 120).
# SHORT_UTTERANCE_MAX_CHARS=120
# Sentence streaming: max sentences (default 2) and max chars (default 280) per translation/TTS chunk.
# STREAM_TRANSLATION_MAX_SENTENCES=2
# STREAM_TRANSLATION_MAX_CHARS=280
